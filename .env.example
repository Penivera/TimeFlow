# TimeFlow Environment Configuration
# Copy this file to .env and update the values as needed

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/timeflow_db
DB_USERNAME=timeflow_user
DB_PASSWORD=secure_password
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Server Configuration
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/timeflow

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_SSL=true
EMAIL_TLS=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30

# Application Configuration
APP_NAME=TimeFlow
APP_VERSION=1.0.0
APP_ENVIRONMENT=development

# Hibernate Configuration
HIBERNATE_DDL_AUTO=update
HIBERNATE_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true
HIBERNATE_USE_SECOND_LEVEL_CACHE=false

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_DIR=./uploads/

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

# Monitoring Configuration
MONITORING_ENABLED=true
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# External Services
EXTERNAL_API_TIMEOUT=5000
EXTERNAL_API_RETRIES=3

# Development Settings
DEV_MODE=true
DEBUG_MODE=false
HOT_RELOAD=false

# Production Settings (Override in production)
PROD_DB_URL=jdbc:postgresql://prod-db:5432/timeflow_prod
PROD_DB_USERNAME=prod_user
PROD_DB_PASSWORD=prod_secure_password

# Cloud Provider Settings (Optional)
# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=timeflow-assets

# Azure
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_STORAGE_ACCOUNT=yourstorageaccount

# GCP
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/backups/timeflow/

# SSL/TLS Configuration
SSL_ENABLED=false
SSL_KEYSTORE_PATH=/path/to/keystore.jks
SSL_KEYSTORE_PASSWORD=keystore-password
SSL_KEY_PASSWORD=key-password

# Session Configuration
SESSION_TIMEOUT=1800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_CAPACITY=20

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Feature Flags
FEATURE_REGISTRATION_ENABLED=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_PASSWORD_RESET=true
FEATURE_CONFLICT_DETECTION=true
FEATURE_NOTIFICATIONS=true
FEATURE_REPORTS=true

# Testing Configuration
TEST_DB_URL=jdbc:postgresql://localhost:5432/timeflow_test
TEST_DB_USERNAME=test_user
TEST_DB_PASSWORD=test_password
TEST_DATA_ENABLED=true

# Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/swagger-ui.html
API_DOCS_PATH=/api-docs

# Internationalization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,fr,de

# Timezone
DEFAULT_TIMEZONE=UTC
